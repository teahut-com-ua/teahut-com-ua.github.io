---
import MainLayout from '../layouts/MainLayout.astro';
import { Image } from 'astro:assets';
import { getCollection } from "astro:content";
import TeaCard from '../components/TeaCard.astro';
import BlogPost from '../components/BlogPost.astro';

import Image1 from "/src/assets/articles/tea-wayfarer.jpg";

const newPosts = (await getCollection('library'))
	.filter((post) => post.data.posted !== false)
	.sort(
		(a, b) => b.data.postedDate.valueOf() - a.data.postedDate.valueOf())
	.slice(0, 2);

const newTeas = (await getCollection('teas'))
	.filter((tea) => tea.data.posted !== false)
	.sort(
		(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);
---

<MainLayout>
	<h1 class="">Ласкаво просимо</h1>
	<h3>до нашої</h3>
	<h2 class="last-line">Чайної Хатинки!</h2>
	<p>
		<Image class="float-left" src={Image1} alt="Чайний мандрівник" />
		
		Кожен із нас шукає своєї досконалости так, як він чи вона розуміє її, залежно від загального знання і контексту, отриманого за своє життя, разом із тим, що закладено в нас Матінкою Природою... <br /> <br />
		<span style="font-size: 1.5em;">М</span>и, як і багато хто до нас, шукаємо Довершености у своєму житті через Чай — через ту Традицію, підвалини якої було закладено ще сивої давнини. Ми не прагнемо відкрити щось нове, досі невідоме. Навпаки, за допомогою простих метод ми глибше занурюємось у навколишнє — у те, що маємо саме цієї миті. Якщо Надзвичайне й існує, воно мусить бути тут і зараз... <span style="font-style: italic;">«Стара хвіртка до Мудрости завжди відкрита. Дзен не має дверей...»</span>
	</p>
	<p class="last-line">
		Так само як і кожна чайна людина минулого й сьогодення, ми не прагнемо віднайти досконалість заради себе. Наша Традиція — це служіння людству через Чай. <span style="font-style: italic;">"Чай і Чань (Дзен)"</span>, казали давні, <span style="font-style: italic;">"мають один смак"</span>. Із глибоким усвідомленням наших зв'язків одне з одним проголошуємо:<br /> <span style="font-weight: 600;">«Най кожна чаша з любов'ю сприяє пробудженню і присутності, розкриттю Гармонії і Спокою Всесвіту в людській свідомості!»</span>
	</p>
	<section class="full-width">
		<h2 class="new-posts-header">Найновіші статті:</h2>
		<div class="new-posts">
			{newPosts.map((p) => 
				<BlogPost
					class="post"
					url={`/library/${p.id}/`}
					title={p.data.title}
					subtitle={p.data.subtitle}
					author={p.data.author}
					description={p.data.description}
					pubDate={p.data.pubDate}
					postedDate={p.data.postedDate}
					categoryTitle={p.data.category.title}
                	categoryUrl={p.data.category.url}
				/>)
			}
		</div>
	</section>
	<section class="tea-section breakout">
		<h2 class="last-line">Наші нові чаї:</h2>
		<div class="new-tea">
			{newTeas.map((tea) => 
				<TeaCard 
					image={tea.data.image} 
					url={`/teas/${tea.id}/`} 
					title={tea.data.title} 
					subtitle={tea.data.subtitle} 
					category={tea.data.category} 
				/>)
			}
		</div>
	</section>
</MainLayout>

<style>
	h1, h2, h3 { text-align: center; }

	p::first-letter { font-size: 1.5em; }

	.new-posts-header { margin-top: 1rem; }
	
	.new-posts, .tea-section { padding: 1rem; }

	.full-width {
		background: var(--button);
	}
	
	.new-posts {
		display: grid;
		grid-auto-flow: dense;
		grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
		grid-template-rows: 1fr auto;
		gap: 2em;
		margin-bottom: .5rem;
	}

	.new-tea {
		display: flex;
		flex-wrap: wrap;
		gap: 2em;
		place-content: start center;
	}

	@media screen  and (min-width: 48rem){		
		.new-tea {
			display: grid;
			grid-template-columns: repeat(3, 1fr);
			grid-template-rows: 1fr;
		}
	}
</style>